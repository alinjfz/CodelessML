# App
SECRET_KEY=your-long-random-secret-key-here
FRONTEND_URL=http://localhost:3000/

# Auth tokens
VERIFICATION_SALT=your-verification-salt-here
RESET_PASSWORD_SALT=your-reset-password-salt-here

# Database (leave default for SQLite)
# DATABASE_URL=sqlite:///codelessml.sqlite

# Email — set MAIL_ENABLED=True and fill in SMTP credentials to enable email sending.
# When False, verification/reset links are returned directly in the API response (dev mode).
MAIL_ENABLED=False
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_USE_TLS=True
MAIL_USE_SSL=False
